@page "/booleansimplifier"

@using ProgramacionDiscreta.Src.AlgebraBooleana.SimplificacionBooleana

@inject IBooleanSimplifierService Simplifier

<PageTitle>Punto 8 - Simplificación Booleana</PageTitle>

<h1>Punto 8: Simplificación booleana (Quine-McCluskey)</h1>
<p>
    Ingresa los minterminos de una función booleana de 3 o 4 variables y obtén
    la expresión simplificada en suma de productos (SOP), junto con la verificación
    de que ambas expresiones tienen la misma tabla de verdad.
</p>

<div class="card p-3 mb-3" style="border:1px solid #ccc; border-radius:8px;">
    <div class="row g-3">
        <div class="col-auto">
            <label class="form-label">Número de variables</label>
            <select class="form-select" @bind="numeroVariables">
                <option value="3">3 (A, B, C)</option>
                <option value="4">4 (A, B, C, D)</option>
            </select>
        </div>

        <div class="col">
            <label class="form-label">Minterminos (separados por coma)</label>
            <input class="form-control" @bind="mintermosTexto" placeholder="Ej: 1,3,5,7" />
        </div>

        <div class="col">
            <label class="form-label">Don't-cares (opcional)</label>
            <input class="form-control" @bind="dontCaresTexto" placeholder="Ej: 2,6" />
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="Simplificar">Simplificar</button>
        <button class="btn btn-outline-secondary" @onclick="CargarCasoDePrueba">
            Cargar caso de prueba {1,3,5,7} (3 variables)
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMensaje))
    {
        <div class="alert alert-danger mt-3">@errorMensaje</div>
    }
</div>

@if (resultado != null)
{
    <div class="card p-3 mb-3" style="border:1px solid #ccc; border-radius:8px;">
        <h3>Resultado</h3>

        <p>
            <strong>Expresión canónica (suma de minterminos):</strong><br />
            @resultado.OriginalExpressionSigma <br />
            @resultado.OriginalExpressionCanonica
        </p>

        <p>
            <strong>Expresión simplificada (SOP):</strong><br />
            <span style="font-size:1.2em; color:#0d6efd;">@resultado.SimplifiedExpression</span>
        </p>

        <p>
            <strong>Compuertas estimadas:</strong>
            original ≈ @resultado.GateCountOriginal &rarr; simplificada ≈ @resultado.GateCountSimplified
        </p>

        <p>
            <strong>¿Misma tabla de verdad?</strong>
            @if (resultado.IsEquivalent)
            {
                <span class="badge bg-success">Equivalente</span>
            }
            else
            {
                <span class="badge bg-danger">NO equivalente</span>
            }
        </p>
    </div>

    <div class="card p-3 mb-3" style="border:1px solid #ccc; border-radius:8px;">
        <h4>Implicantes primos</h4>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Patrón</th>
                    <th>Expresión</th>
                    <th>Minterminos que cubre</th>
                    <th>Esencial</th>
                    <th>Seleccionado</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pi in resultado.AllPrimeImplicants.OrderBy(p => p.Pattern))
                {
                    <tr>
                        <td><code>@pi.Pattern</code></td>
                        <td>@pi.ToLiteralExpression(resultado.VariableNames)</td>
                        <td>@string.Join(", ", pi.Minterms.OrderBy(m => m))</td>
                        <td>@(pi.IsEssential ? "Sí" : "")</td>
                        <td>@(resultado.SelectedPrimeImplicants.Contains(pi) ? "Sí" : "")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card p-3 mb-3" style="border:1px solid #ccc; border-radius:8px;">
        <h4>Tabla de verdad comparativa</h4>
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Binario</th>
                    <th>Original</th>
                    <th>Simplificada</th>
                    <th>Coincide</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in resultado.TruthTable)
                {
                    <tr style="@(row.Match ? "" : "background-color:#f8d7da;")">
                        <td>@row.Index</td>
                        <td><code>@row.Binary</code></td>
                        <td>@(row.IsDontCare ? "X" : row.OriginalOutput.ToString())</td>
                        <td>@row.SimplifiedOutput</td>
                        <td>@(row.Match ? "✔" : "✘")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card p-3 mb-3" style="border:1px solid #ccc; border-radius:8px;">
        <h4>Explicación paso a paso</h4>
        <ul>
            @foreach (var paso in resultado.Steps)
            {
                <li>@paso</li>
            }
        </ul>
    </div>
}

@code {
    private int numeroVariables = 3;
    private string mintermosTexto = "";
    private string dontCaresTexto = "";
    private string? errorMensaje;
    private SimplificationResultModel? resultado;

    private void CargarCasoDePrueba()
    {
        numeroVariables = 3;
        mintermosTexto = "1,3,5,7";
        dontCaresTexto = "";
        Simplificar();
    }

    private void Simplificar()
    {
        errorMensaje = null;
        resultado = null;

        try
        {
            var minterminos = ParseIntList(mintermosTexto);
            var dontCares = ParseIntList(dontCaresTexto);

            var request = new SimplificationRequestModel
                {
                    NumberOfVariables = numeroVariables,
                    Minterms = minterminos,
                    DontCares = dontCares
                };

            resultado = Simplifier.Simplify(request);
        }
        catch (Exception ex)
        {
            errorMensaje = $"Error: {ex.Message}";
        }
    }

    private static List<int> ParseIntList(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return new List<int>();

        return texto
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => int.Parse(s))
            .ToList();
    }
}
