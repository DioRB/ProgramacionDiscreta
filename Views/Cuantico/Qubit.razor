@page "/qubitsimulator"

@using ProgramacionDiscreta.Src.Cuantico

@inject QuantumSimulationService SimulationService
@inject MeasurementService MeasurementService

<PageTitle>Simulador de Qubit</PageTitle>

<h3>Primer simulador cuántico</h3>

<div class="mb-3">

    <label class="form-label">
        Estado inicial
    </label>

    <InputRadioGroup @bind-Value="StartInZero">

        <div>
            <InputRadio Value="true" />
            <span>|0⟩</span>
        </div>

        <div>
            <InputRadio Value="false" />
            <span>|1⟩</span>
        </div>

    </InputRadioGroup>

</div>

<div class="mb-3">

    <label class="form-label">
        Secuencia de compuertas
    </label>

    <input class="form-control"
           @bind="GateSequence"
           placeholder="Ej: X, H, HH, HX, XZH..." />

    <small class="text-muted">
        Utilice únicamente X, Z y H.
    </small>

</div>

<div class="mb-3">

    <label class="form-label">
        Número de mediciones
    </label>

    <input class="form-control"
           type="number"
           min="1"
           @bind="Measurements" />

</div>

<button class="btn btn-primary"
        @onclick="RunSimulation">
    Simular
</button>

@if (Result is not null)
{
    <hr />

    <h4>Estado final</h4>

    <p>

        <strong>α:</strong>
        @Result.State.Alpha.ToString("F6")

    </p>

    <p>

        <strong>β:</strong>
        @Result.State.Beta.ToString("F6")

    </p>

    <p>

        <strong>Vector:</strong>

        @SimulationService.GetStateAsString(Result.State)

    </p>

    <hr />

    <h4>Probabilidades teóricas</h4>

    <table class="table table-bordered">

        <thead>

            <tr>
                <th>Medición</th>
                <th>Probabilidad</th>
            </tr>

        </thead>

        <tbody>

            <tr>

                <td>|0⟩</td>

                <td>
                    @((Result.Measurement.Probability0 * 100).ToString("F2")) %
                </td>

            </tr>

            <tr>

                <td>|1⟩</td>

                <td>
                    @((Result.Measurement.Probability1 * 100)
                    .ToString("F2")) %
                </td>

            </tr>

        </tbody>

    </table>

    <hr />

    <h4>Simulación de mediciones</h4>

    <table class="table table-striped table-bordered">

        <thead>

            <tr>

                <th>Resultado</th>

                <th>Frecuencia</th>

                <th>Probabilidad observada</th>

            </tr>

        </thead>

        <tbody>

            <tr>

                <td>|0⟩</td>

                <td>@Result.Measurement.Measured0</td>

                <td>

                    @((MeasurementService
                        .GetObservedProbability0(
                        Result.Measurement) * 100)
                    .ToString("F2")) %

                </td>

            </tr>

            <tr>

                <td>|1⟩</td>

                <td>@Result.Measurement.Measured1</td>

                <td>

                    @((MeasurementService
                        .GetObservedProbability1(
                        Result.Measurement) * 100)
                    .ToString("F2")) %

                </td>

            </tr>

        </tbody>

    </table>
}

@code
{
    private bool StartInZero = true;

    private string GateSequence = "";

    private int Measurements = 1000;

    private SimulationResultModel? Result;

    private void RunSimulation()
    {
        GateSequence = GateSequence
            .Trim()
            .ToUpper();

        Result = SimulationService.Simulate(
            StartInZero,
            GateSequence,
            Measurements);
    }
}