@page "/shannon"

@using ProgramacionDiscreta.Src.Shannon

@inject EntropiaShannonService EntropyService
@inject ComparacionShannonService ComparisonService

<PageTitle>Entropía de Shannon</PageTitle>

<h3>Entropía de Shannon</h3>

<div class="row">

    <div class="col-md-6">

        <label class="form-label">
            Texto 1
        </label>

        <textarea class="form-control"
                  rows="4"
                  @bind="Text1">
        </textarea>

    </div>

    <div class="col-md-6">

        <label class="form-label">
            Texto 2
        </label>

        <textarea class="form-control"
                  rows="4"
                  @bind="Text2">
        </textarea>

    </div>

</div>

<br />

<button class="btn btn-primary"
        @onclick="AnalyzeTexts">
    Analizar
</button>

@if (Result1 is not null && Result2 is not null)
{
    <hr />

    <div class="row">

        <div class="col-md-6">

            <h4>Texto 1</h4>

            <p>
                <strong>Longitud:</strong> @Result1.Length
            </p>

            <p>
                <strong>Entropía:</strong>
                @Result1.Entropy.ToString("F4") bits
            </p>

            <table class="table table-bordered table-striped">

                <thead>

                    <tr>
                        <th>Símbolo</th>
                        <th>Frecuencia</th>
                        <th>Probabilidad</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var symbol in Result1.Symbols)
                    {
                        <tr>

                            <td>@DisplaySymbol(symbol.Symbol)</td>

                            <td>@symbol.Frequency</td>

                            <td>@symbol.Probability.ToString("F4")</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

        <div class="col-md-6">

            <h4>Texto 2</h4>

            <p>
                <strong>Longitud:</strong> @Result2.Length
            </p>

            <p>
                <strong>Entropía:</strong>
                @Result2.Entropy.ToString("F4") bits
            </p>

            <table class="table table-bordered table-striped">

                <thead>

                    <tr>
                        <th>Símbolo</th>
                        <th>Frecuencia</th>
                        <th>Probabilidad</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var symbol in Result2.Symbols)
                    {
                        <tr>

                            <td>@DisplaySymbol(symbol.Symbol)</td>

                            <td>@symbol.Frequency</td>

                            <td>@symbol.Probability.ToString("F4")</td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <hr />

    <h4>Comparación</h4>

    <div class="alert alert-info">

        @Comparison?.Conclusion

    </div>
}

@code
{
    private string Text1 = "";

    private string Text2 = "";

    private ResultadoShannonModel? Result1;

    private ResultadoShannonModel? Result2;

    private ResultadoComparacionModel? Comparison;

    private void AnalyzeTexts()
    {
        Result1 = EntropyService.Analyze(Text1);

        Result2 = EntropyService.Analyze(Text2);

        Comparison =
            ComparisonService.Compare(
                Result1,
                Result2);
    }

    private string DisplaySymbol(char symbol)
    {
        return symbol switch
        {
            ' ' => "[espacio]",
            '\t' => "[tab]",
            '\n' => "[salto de línea]",
            _ => symbol.ToString()
        };
    }
}